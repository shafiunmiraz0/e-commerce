<%- include('../partials/header') %>

<section class="account-page">
  <div class="container">
    <div class="account-layout">
      <aside class="account-sidebar">
        <div class="account-user">
          <div class="account-avatar"><i class="fas fa-user-circle"></i></div>
          <h3><%= profile.full_name || profile.username %></h3>
          <span><%= profile.email %></span>
        </div>
        <nav class="account-nav">
          <a href="/account" class="account-nav-link <%= activeTab === 'overview' ? 'active' : '' %>"><i class="fas fa-th-large"></i> Overview</a>
          <a href="/account/orders" class="account-nav-link <%= activeTab === 'orders' ? 'active' : '' %>"><i class="fas fa-box"></i> My Orders</a>
          <a href="/account/profile" class="account-nav-link <%= activeTab === 'profile' ? 'active' : '' %>"><i class="fas fa-id-card"></i> Profile</a>
          <hr>
          <a href="/" class="account-nav-link"><i class="fas fa-store"></i> Back to Store</a>
          <a href="/logout" class="account-nav-link text-danger"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>
      </aside>

      <main class="account-main">
        <h2><i class="fas fa-id-card"></i> My Profile</h2>

        <div class="profile-card-large">
          <div class="profile-header-section">
            <div class="profile-avatar-large"><i class="fas fa-user-circle"></i></div>
            <div class="profile-header-info">
              <h3><%= profile.full_name || profile.username %></h3>
              <span class="profile-role-badge"><%= profile.role %></span>
              <p>Member since <%= new Date(profile.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long' }) %></p>
            </div>
          </div>
        </div>

        <div class="account-card">
          <div class="account-card-header">
            <h3><i class="fas fa-edit"></i> Update Profile</h3>
          </div>
          <form action="/account/profile" method="POST" class="profile-form">
            <div class="form-group">
              <label><i class="fas fa-id-card"></i> Full Name</label>
              <input type="text" name="full_name" value="<%= profile.full_name || '' %>" placeholder="Your full name">
            </div>
            <div class="form-group">
              <label><i class="fas fa-phone"></i> Phone</label>
              <input type="text" name="phone" value="<%= profile.phone || '' %>" placeholder="Phone number">
            </div>
            <div class="form-group">
              <label><i class="fas fa-map-marker-alt"></i> Address</label>
              <textarea name="address" placeholder="Your address"><%= profile.address || '' %></textarea>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label><i class="fas fa-city"></i> City</label>
                <input type="text" name="city" value="<%= profile.city || '' %>" placeholder="City">
              </div>
              <div class="form-group">
                <label><i class="fas fa-globe"></i> Country</label>
                <input type="text" name="country" value="<%= profile.country || '' %>" placeholder="Country">
              </div>
            </div>
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Changes</button>
          </form>
        </div>
      </main>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
