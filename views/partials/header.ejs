<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
  <div class="announcement-bar">
    <div class="container">
      <div class="announcement-slider">
        <span class="announcement-item active"><i class="fas fa-truck"></i> Free Shipping on Orders Over $50</span>
        <span class="announcement-item"><i class="fas fa-shield-alt"></i> Secure Checkout - 100% Protected</span>
        <span class="announcement-item"><i class="fas fa-undo"></i> 30-Day Money-Back Guarantee</span>
        <span class="announcement-item"><i class="fas fa-headset"></i> 24/7 Customer Support</span>
      </div>
    </div>
  </div>

  <nav class="navbar">
    <div class="container nav-container">
      <a href="/" class="logo">
        <span class="logo-icon"><i class="fas fa-bolt"></i></span>
        <span class="logo-text">Shop<span class="logo-highlight">Vue</span></span>
      </a>

      <form class="search-bar" action="/products" method="GET" autocomplete="off">
        <input type="text" name="search" placeholder="Search for products..." value="<%= typeof currentSearch !== 'undefined' ? currentSearch : '' %>">
        <button type="submit"><i class="fas fa-search"></i></button>
        <div class="search-autocomplete"></div>
      </form>

      <div class="nav-links">
        <a href="/products"><i class="fas fa-th-large"></i> Products</a>
        <% if (user) { %>
          <a href="/wishlist" class="wishlist-link">
            <i class="fas fa-heart"></i> Wishlist
          </a>
          <a href="/cart" class="cart-link">
            <i class="fas fa-shopping-cart"></i> Cart
          </a>
          <div class="dropdown">
            <button class="dropdown-btn" onclick="toggleDropdown(event)">
              <i class="fas fa-user-circle"></i> <%= user.full_name || user.username %>
              <i class="fas fa-chevron-down"></i>
            </button>
            <div class="dropdown-menu">
              <a href="/account"><i class="fas fa-th-large"></i> My Account</a>
              <a href="/account/orders"><i class="fas fa-box"></i> My Orders</a>
              <a href="/account/profile"><i class="fas fa-id-card"></i> Profile</a>
              <% if (user.role === 'admin') { %>
                <hr>
                <a href="/admin"><i class="fas fa-cog"></i> Admin Panel</a>
              <% } %>
              <hr>
              <a href="/logout" class="text-danger"><i class="fas fa-sign-out-alt"></i> Logout</a>
            </div>
          </div>
        <% } else { %>
          <a href="/login" class="btn btn-sm btn-primary">Login</a>
          <a href="/register" class="btn btn-sm btn-outline">Sign Up</a>
        <% } %>
      </div>

      <button class="mobile-menu-btn" onclick="">
        <i class="fas fa-bars"></i>
      </button>
    </div>
  </nav>

  <!-- Mobile drawer overlay -->
  <div class="mobile-drawer-overlay" id="mobile-drawer-overlay"></div>
  <!-- Mobile slide-in drawer -->
  <div class="mobile-drawer" id="mobile-drawer">
    <div class="mobile-drawer-header">
      <h3><i class="fas fa-bolt" style="color:var(--primary)"></i> ShopVue</h3>
      <button class="mobile-drawer-close"><i class="fas fa-times"></i></button>
    </div>
    <div class="mobile-drawer-links">
      <a href="/products"><i class="fas fa-th-large"></i> All Products</a>
      <% if (user) { %>
        <a href="/wishlist"><i class="fas fa-heart"></i> Wishlist</a>
        <a href="/cart"><i class="fas fa-shopping-cart"></i> Cart</a>
        <div class="drawer-divider"></div>
        <a href="/account"><i class="fas fa-user-circle"></i> My Account</a>
        <a href="/account/orders"><i class="fas fa-box"></i> My Orders</a>
        <a href="/account/profile"><i class="fas fa-id-card"></i> Profile</a>
        <% if (user.role === 'admin') { %>
          <div class="drawer-divider"></div>
          <a href="/admin"><i class="fas fa-cog"></i> Admin Panel</a>
        <% } %>
        <div class="drawer-divider"></div>
        <a href="/logout" class="drawer-danger"><i class="fas fa-sign-out-alt"></i> Logout</a>
      <% } else { %>
        <div class="drawer-divider"></div>
        <a href="/login"><i class="fas fa-sign-in-alt"></i> Login</a>
        <a href="/register"><i class="fas fa-user-plus"></i> Sign Up</a>
      <% } %>
    </div>
  </div>

  <!-- Bottom tab bar (mobile only) -->
  <div class="bottom-tab-bar">
    <div class="bottom-tab-bar-inner">
      <a href="/" class="bottom-tab <%= typeof title !== 'undefined' && title === 'Home' ? 'active' : '' %>">
        <i class="fas fa-home"></i>
        <span>Home</span>
      </a>
      <a href="/products" class="bottom-tab <%= typeof title !== 'undefined' && title === 'Products' ? 'active' : '' %>">
        <i class="fas fa-th-large"></i>
        <span>Products</span>
      </a>
      <a href="/wishlist" class="bottom-tab">
        <i class="fas fa-heart"></i>
        <span>Wishlist</span>
        <% if (typeof wishlistCount !== 'undefined' && wishlistCount > 0) { %>
          <span class="tab-badge"><%= wishlistCount %></span>
        <% } %>
      </a>
      <a href="/cart" class="bottom-tab">
        <i class="fas fa-shopping-cart"></i>
        <span>Cart</span>
        <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
          <span class="tab-badge"><%= cartCount %></span>
        <% } %>
      </a>
      <a href="<%= user ? '/account' : '/login' %>" class="bottom-tab">
        <i class="fas fa-user"></i>
        <span><%= user ? 'Account' : 'Login' %></span>
      </a>
    </div>
  </div>

  <!-- Page transition overlay -->
  <div class="page-transition-overlay" id="page-transition"></div>

  <main>
    <div class="container">
      <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
        <div class="alert alert-success" data-flash>
          <i class="fas fa-check-circle"></i> <%= success %>
          <button onclick="this.parentElement.remove()" class="alert-close">&times;</button>
        </div>
      <% } %>
      <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
        <div class="alert alert-error" data-flash>
          <i class="fas fa-exclamation-circle"></i> <%= error %>
          <button onclick="this.parentElement.remove()" class="alert-close">&times;</button>
        </div>
      <% } %>
      <% if (typeof info !== 'undefined' && info && info.length > 0) { %>
        <div class="alert alert-info" data-flash>
          <i class="fas fa-info-circle"></i> <%= info %>
          <button onclick="this.parentElement.remove()" class="alert-close">&times;</button>
        </div>
      <% } %>
    </div>
